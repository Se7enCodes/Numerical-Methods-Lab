#include <stdio.h>
#include <math.h>

double f(double x) {
    return x*x*x - x - 2;
}

void secant(double x0, double x1, double tol) {
    double x2;
    int step = 1;

    printf("Step\tx0\tx1\tx2\n");

    while (fabs(x1 - x0) >= tol) {
        x2 = x1 - (f(x1) * (x1 - x0)) / (f(x1) - f(x0));

        printf("%d\t%.4f\t%.4f\t%.4f\n", step++, x0, x1, x2);

        x0 = x1;
        x1 = x2;
    }

    printf("\nRoot = %.6f\n", x2);
}

int main() {
    secant(1, 2, 0.0001);
    return 0;
}
